# AI 配置文件示例
# 复制此文件为 .env 并填入你的实际配置

# AI API Key
# OpenAI: 在 https://platform.openai.com/api-keys 获取
# 通义千问: 在 https://dashscope.console.aliyun.com/apiKey 获取
# 讯飞星火: 在 https://console.xfyun.cn/services/cbm 获取
VUE_APP_AI_API_KEY=your_api_key_here

# AI API 端点
# OpenAI: https://api.openai.com/v1/chat/completions
# 通义千问: https://dashscope.aliyuncs.com/api/v1/services/aigc/text-generation/generation
# 讯飞星火: https://spark-api.xf-yun.com/v3.5/chat
VUE_APP_AI_API_ENDPOINT=https://api.openai.com/v1/chat/completions

# AI 模型名称
# OpenAI: gpt-3.5-turbo, gpt-4
# 通义千问: qwen-turbo, qwen-plus, qwen-max
# 讯飞星火: spark-lite, spark-pro, spark-max
VUE_APP_AI_MODEL=gpt-3.5-turbo

# 后端API配置
# 开发环境：http://localhost:3000
# 生产环境：https://api.jiaandmiya.com
VITE_API_BASE_URL=http://localhost:3000/api
