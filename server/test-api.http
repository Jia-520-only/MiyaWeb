# jiaandmiya.com API 测试脚本
# 可以使用 VS Code REST Client 扩展进行测试

### 健康检查
GET http://localhost:3000/api/health

### 用户注册
POST http://localhost:3000/api/auth/register
Content-Type: application/json

{
  "username": "testuser",
  "email": "test@example.com",
  "password": "Test123456",
  "confirmPassword": "Test123456",
  "displayName": "测试用户"
}

### 用户登录
POST http://localhost:3000/api/auth/login
Content-Type: application/json

{
  "username": "admin",
  "password": "admin123"
}

> {%
  client.test("登录成功", function() {
    client.assert(response.status === 200, "登录失败");
    client.assert(response.body.token, "缺少token");
    client.global.set("auth_token", response.body.token);
  });
%}

### 获取当前用户信息
GET http://localhost:3000/api/auth/me
Authorization: Bearer {{auth_token}}

### 获取文章列表
GET http://localhost:3000/api/articles?limit=5

### 获取文章分类
GET http://localhost:3000/api/articles/categories/all

### 获取内容项列表
GET http://localhost:3000/api/content
Authorization: Bearer {{auth_token}}

### 获取页面列表
GET http://localhost:3000/api/content/pages/list

### 获取指定页面内容（公开）
GET http://localhost:3000/api/content/page/home

### 创建测试文章
POST http://localhost:3000/api/articles
Authorization: Bearer {{auth_token}}
Content-Type: application/json

{
  "title": "测试文章标题",
  "content": "这是一篇测试文章的内容。\n\n包含多个段落。\n\n- 列表项1\n- 列表项2\n- 列表项3",
  "summary": "文章摘要",
  "tags": ["测试", "教程"],
  "is_published": true
}

### 上传测试图片
POST http://localhost:3000/api/upload/single
Authorization: Bearer {{auth_token}}
Content-Type: multipart/form-data; boundary=WebAppBoundary

--WebAppBoundary
Content-Disposition: form-data; name="file"; filename="test.jpg"
Content-Type: image/jpeg

< ./test-image.jpg
--WebAppBoundary--

### 获取文件列表
GET http://localhost:3000/api/upload
Authorization: Bearer {{auth_token}}

### 获取图片库
GET http://localhost:3000/api/upload/gallery/images?limit=5

### 更新用户资料
PUT http://localhost:3000/api/auth/profile
Authorization: Bearer {{auth_token}}
Content-Type: application/json

{
  "displayName": "新的显示名称",
  "bio": "这是我的个人简介",
  "avatar": "https://example.com/avatar.jpg"
}

### 修改密码
POST http://localhost:3000/api/auth/change-password
Authorization: Bearer {{auth_token}}
Content-Type: application/json

{
  "currentPassword": "admin123",
  "newPassword": "NewPassword123",
  "confirmPassword": "NewPassword123"
}

### 获取热门文章
GET http://localhost:3000/api/articles/popular/trending?limit=3

### 搜索建议
GET http://localhost:3000/api/articles/search/suggestions?q=测试

### 退出登录
POST http://localhost:3000/api/auth/logout
Authorization: Bearer {{auth_token}}