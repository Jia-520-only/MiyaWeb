# 服务器配置
PORT=3000
NODE_ENV=development

# JWT配置
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# 数据库配置
DATABASE_PATH=./database/jiaandmiya.db

# 文件上传配置
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880 # 5MB
ALLOWED_EXTENSIONS=jpg,jpeg,png,gif,webp,pdf,md,txt

# 管理员账户
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@jiaandmiya.com
ADMIN_PASSWORD=change_me_please

# CORS配置
CORS_ORIGIN=http://localhost:5173,https://jiaandmiya.com